{
  "name": "nonprofit-explorer-mcp-server",
  "version": "0.1.4",
  "description": "MCP server for US nonprofit financials via ProPublica — IRS Form 990 data for 1.8M+ tax-exempt organizations.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/nonprofit-explorer-mcp-server#readme",
  "repository": "https://github.com/cyanheads/nonprofit-explorer-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "nonprofit-explorer-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/nonprofit-explorer-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
